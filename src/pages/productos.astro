---
import Layout from "../layouts/main.astro";
import Header from "../uis/header.astro";
import Footer from "../uis/footer.astro";
import ProductCard from "../uis/productCard.astro";
import CatalogHeader from "../uis/CatalogHeader.astro";
import FilterSidebar from "../uis/FilterSidebar.astro";
import SortSidebar from "../uis/SortSidebar.astro";
import { SlidersHorizontal, ArrowUpDown } from "lucide-react"; 
import { productsData as products } from "../services/productos";

const title = "Productos Electrónicos";
const links = [{ label: "Home", href: "/" }, { label: "Productos", href: "/productos/" }];
const categories = ["Todos", "Celulares", "Accesorios / Cargadores", "Accesorios / Cables", "Audio"];
---

<Layout>
  <div class="min-h-screen bg-[#F8F9FA] flex flex-col justify-between font-sans antialiased text-neutral-800 selection:bg-orange-500/10 selection:text-orange-600">
    <div>
      <Header />
      
      {/* 1. SECCIÓN CABECERA */}
      <CatalogHeader title={title} links={links} />

      {/* BARRA DE ACCESO RÁPIDO PARA MÓVILES */}
      <div class="bg-white border-b border-neutral-100 lg:hidden py-2 px-4 overflow-x-auto flex items-center justify-between gap-2 sticky top-0 z-20 shadow-xs">
        <div class="flex items-center gap-1.5 overflow-x-auto scrollbar-none flex-1">
          <button 
            id="btn-open-filters" 
            class="flex items-center gap-1 bg-neutral-900 text-white rounded-lg px-2.5 py-1.5 text-[11px] font-bold shadow-xs whitespace-nowrap"
          >
            <SlidersHorizontal className="w-3 h-3" client:load />
            Filtros
          </button>
          <div class="w-[1px] bg-neutral-200 h-4 flex-shrink-0"></div>
          {categories.slice(1).map((category) => (
            <button 
              class="mobile-quick-tag px-2.5 py-1.5 bg-neutral-50 border border-neutral-200/60 rounded-lg text-[11px] font-medium text-neutral-500 whitespace-nowrap transition-colors"
              data-value={category}
            >
              {category.replace("Accesorios / ", "")}
            </button>
          ))}
        </div>

        <button 
          id="btn-open-sort" 
          class="flex items-center gap-1 bg-white border border-neutral-200 text-neutral-700 rounded-lg px-2.5 py-1.5 text-[11px] font-bold shadow-xs whitespace-nowrap"
        >
          <ArrowUpDown className="w-3 h-3" client:load />
          Ordenar
        </button>
      </div>
      
      {/* CONTENEDOR PRINCIPAL TRIPLE */}
      <section class="py-5 sm:py-8 max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="flex flex-col lg:flex-row gap-6 items-start">
          
          {/* 2. BARRA LATERAL IZQUIERDA - FILTROS */}
          <FilterSidebar categories={categories} />

          {/* 3. AREA CENTRAL - CUADRÍCULA DE PRODUCTOS */}
          <div class="flex-1 w-full min-w-0">
            <div id="no-products-msg" class="hidden text-center py-14 bg-white rounded-2xl border border-dashed border-neutral-200 mb-6 px-4">
              <p class="text-neutral-400 text-xs font-medium">Sin resultados para los filtros actuales.</p>
            </div>

            <div id="grid-products" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-3 sm:gap-4">
              {products.map((product) => (
                <ProductCard product={product} />
              ))}
            </div>
          </div>

          {/* 4. BARRA LATERAL DERECHA - ORDENAMIENTO */}
          <SortSidebar />
 
        </div>
      </section>
    </div>
    <Footer />
  </div>
</Layout>

{/* SCRIPT DE CONTROL REFACTORIZADO */}
<script>
  import { initEcommerceFilters } from "../scripts/ecommerce-filters";

  // Inicializa la lógica en la carga de la página
  initEcommerceFilters();

  // Escucha el evento de Astro por si usas View Transitions para que no se rompa al navegar
  document.addEventListener('astro:page-load', initEcommerceFilters);
</script>

<style>
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>