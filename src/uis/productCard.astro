---
// src/components/ProductCard.astro
import { Button } from "../components/button";
import { Card, CardTitle } from "../components/card";
import { ShoppingCart, Star } from "lucide-react"; 

// QUITAMOS la importación del servicio de aquí

interface Props {
  product: {
    id: string | number;
    name: string;
    category: string;
    price: number;
    priceString: string;
    oldPrice?: string;
    rating: number;
    image: string;
    badge?: string | null;
    specs: string[];
  };
}

const { product } = Astro.props;
console.log("🚀 ~ product:", product)
---

<div 
  class="product-card transition-all duration-300 h-full" 
  data-name={product?.name?.toLowerCase()}
  data-category={product?.category} 
  data-price={product?.price}
  data-rating={product?.rating}
>
  <Card className="group relative flex flex-col h-full w-full overflow-hidden bg-white border border-neutral-200/60 shadow-xs rounded-xl transition-all duration-300 hover:shadow-md hover:border-neutral-300">
    
    {product.badge && (
      <div class="absolute top-2 left-2 z-10 bg-neutral-900/90 backdrop-blur-xs text-white text-[9px] font-bold px-1.5 py-0.5 rounded-md pointer-events-none uppercase tracking-wide">
        {product.badge}
      </div>
    )}

    <div class="relative aspect-square w-full overflow-hidden bg-neutral-50/50 border-b border-neutral-100 flex-shrink-0">
      <img 
        src={product.image} 
        alt={product.name} 
        class="h-full w-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-102"
        loading="lazy"
      />
    </div>

    <div class="p-3 flex-grow flex flex-col justify-between gap-2.5">
      <div>
        <div class="flex items-center justify-between gap-1">
          <span class="text-[9px] font-bold text-neutral-400 uppercase tracking-wider truncate max-w-[70%]">
            {product.category?.replace("Accesorios / ", "")}
          </span>
          <div class="flex items-center gap-0.5 bg-neutral-50 px-1 py-0.5 rounded">
            <Star className="w-2.5 h-2.5 fill-amber-400 text-amber-400 flex-shrink-0" client:load />
            <span class="text-[9px] font-bold text-neutral-500">{product.rating}</span>
          </div>
        </div>

        <CardTitle className="text-xs font-bold text-neutral-800 line-clamp-2 min-h-[2rem] mt-1 leading-tight tracking-tight group-hover:text-neutral-900 transition-colors" client:load>
          {product.name}
        </CardTitle>
        
        <div class="flex flex-wrap gap-1 mt-2 overflow-hidden max-h-5 hidden sm:flex">
          {product.specs?.slice(0, 2).map((spec) => (
            <span class="text-[9px] font-medium bg-neutral-50 text-neutral-400 px-1.5 py-0.5 rounded border border-neutral-100 max-w-full truncate">
              {spec}
            </span>
          ))}
        </div>
      </div>

      <div class="pt-2 border-t border-neutral-100 flex items-center justify-between gap-1.5">
        <div class="min-w-0">
          {product.oldPrice && (
            <span class="text-[10px] text-neutral-400 line-through block leading-none mb-0.5">${product.oldPrice}</span>
          )}
          <div class="flex items-baseline gap-0.5 truncate">
            <span class="text-sm font-extrabold text-neutral-900 tracking-tight">${product.priceString}</span>
            <span class="text-[8px] font-bold text-neutral-400">COP</span>
          </div>
        </div>

        <Button className="h-7 w-7 bg-neutral-50 group-hover:bg-neutral-900 border border-neutral-200 group-hover:border-neutral-900 text-neutral-700 group-hover:text-white flex items-center justify-center rounded-lg p-0 transition-all active:scale-95 flex-shrink-0" client:load>
          <ShoppingCart className="w-3 h-3" client:load />
          <span class="sr-only">Añadir al carrito</span>
        </Button>
      </div>
    </div>
  </Card>
</div>