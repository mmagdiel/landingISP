---
const securitySection = {
  badge: "Temas de vital importancia",
  title: "Un internet seguro y confiable para todos",
  content: "Las regulaciones para los entornos de internet son cruciales para garantizar la seguridad, privacidad y bienestar de los usuarios en línea. En un mundo cada vez más digital, donde la mayoría de las personas realizan gran parte de sus actividades en línea, es esencial contar con regulaciones claras y efectivas que protejan los derechos y la dignidad de los usuarios."
};
---

<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-orange-600 font-semibold mb-2">{securitySection.badge}</div>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{securitySection.title}</h2>
      <p class="text-gray-600 text-lg leading-relaxed">
        {securitySection.content}
      </p>
    </div>
  </div>
</section>