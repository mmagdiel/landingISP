---
import Breadcrumb from "../uis/breadcrumb.astro";
import { Search } from "lucide-react";

interface Props {
  title: string;
  links: { label: string; href: string }[];
}

const { title, links } = Astro.props;
---
<div class="bg-white border-b border-neutral-200/50 py-4 sm:py-6">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
    <Breadcrumb title={title} links={links} />
    <div class="mt-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h1 class="text-xl sm:text-2xl font-bold tracking-tight text-neutral-900">Catálogo de Componentes</h1>
        <p class="text-xs text-neutral-400 mt-0.5">Equipos premium seleccionados con la mayor precisión técnica.</p>
      </div>
      
      {/* BUSCADOR ESTILIZADO */}
      <div class="relative w-full sm:w-72 lg:w-80 group">
        <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-neutral-400 group-focus-within:text-neutral-900 transition-colors pointer-events-none" client:load />
        <input 
          type="text" 
          id="search-input"
          placeholder="Buscar dispositivo..." 
          class="w-full pl-9 pr-4 py-2 bg-neutral-50 border border-neutral-200 rounded-xl text-xs focus:outline-none focus:ring-2 focus:ring-neutral-200 focus:border-neutral-400 focus:bg-white transition-all text-neutral-800 font-medium"
        />
      </div>
    </div>
  </div>
</div>